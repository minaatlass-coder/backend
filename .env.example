# =============================================================================
# EasyPanel — service API (domaine : api.sahha.online)
# Onglet Environment du service backend
# =============================================================================

NODE_ENV=production
PORT=4000

# Postgres (EasyPanel → postgres → Informations d'identification)
# Hôte interne Docker : sahhaonline_database (pas l'IP publique)
DATABASE_URL=postgres://postgres:MOT_DE_PASSE@sahhaonline_database:5432/sahhaonline?sslmode=disable

# Webhook commandes / contact (Make, n8n, Google Apps Script)
# Vide en dev → payloads loggés dans la console
ORDER_WEBHOOK_URL=

# Sel pour hacher les IP visiteurs (32+ caractères aléatoires, secret)
IP_HASH_SALT=

# Meta CAPI
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# TikTok Events API
TIKTOK_PIXEL_ID=
TIKTOK_EVENTS_API_ACCESS_TOKEN=

# Origines autorisées pour les requêtes du navigateur (frontend)
CORS_ORIGINS=https://sahha.online,https://www.sahha.online
